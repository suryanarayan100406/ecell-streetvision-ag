# ═══════════════════════════════════════════════════════════════════
# AUTONOMOUS POTHOLE INTELLIGENCE SYSTEM — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in all values
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pothole_user:pothole_pass@db:5432/pothole_db
POSTGRES_USER=pothole_user
POSTGRES_PASSWORD=pothole_pass
POSTGRES_DB=pothole_db

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ──────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
ADMIN_DEFAULT_EMAIL=admin@potholeai.in
ADMIN_DEFAULT_PASSWORD=change-this-admin-password

# ── ESA Copernicus (Sentinel-1, Sentinel-2) ───────────────────────
SENTINEL_USER=
SENTINEL_PASS=
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=

# ── ISRO Bhoonidhi (CARTOSAT-3, CARTOSAT-2S, ResourceSat-2A, RISAT-2B, EOS-04)
BHOONIDHI_USERNAME=
BHOONIDHI_PASSWORD=

# ── USGS/NASA Landsat ─────────────────────────────────────────────
USGS_USERNAME=
USGS_PASSWORD=
USGS_M2M_API_KEY=

# ── NASA Earthdata (MODIS, VIIRS) ────────────────────────────────
NASA_EARTHDATA_USER=
NASA_EARTHDATA_PASS=

# ── JAXA ALOS-2 ──────────────────────────────────────────────────
JAXA_AUIG2_USER=
JAXA_AUIG2_PASS=

# ── Google Earth Engine ──────────────────────────────────────────
GEE_SERVICE_ACCOUNT_KEY_PATH=/app/credentials/gee-service-account.json

# ── Google Gemini AI ─────────────────────────────────────────────
GEMINI_API_KEY=

# ── PG Portal (Complaint Filing) ─────────────────────────────────
PG_PORTAL_USER=
PG_PORTAL_PASS=

# ── Weather APIs ─────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=
# IMD and Open-Meteo require no API keys

# ── Government Data ──────────────────────────────────────────────
DATAGOVIN_API_KEY=

# ── Street-Level Imagery ─────────────────────────────────────────
MAPILLARY_ACCESS_TOKEN=

# ── NRSC Data Portal ─────────────────────────────────────────────
NRSC_DATA_USERNAME=
NRSC_DATA_PASSWORD=

# ── Frontend ─────────────────────────────────────────────────────
VITE_MAPBOX_TOKEN=
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=http://localhost:8000

# ── SMTP (Email Fallback) ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=pothole-system@potholeai.in
SMTP_FROM_NAME=Pothole Intelligence System

# ── MinIO Object Storage ─────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=pothole-data

# ── SNAP (SAR Processing) ────────────────────────────────────────
SNAP_HOME=/opt/snap

# ── Grafana ──────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin

# ── MLflow ───────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
